# Supabase — required for waitlist signups and dynamic content (testimonials, FAQs)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: server-side service role key for the waitlist API route
# (falls back to anon key if not set — works with the RLS policy)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: brand customization (used at build time or via CSS variables)
NEXT_PUBLIC_BRAND_NAME=Acme
NEXT_PUBLIC_BRAND_TAGLINE=Build something amazing
